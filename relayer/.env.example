# --- Solana ---
RPC_URL=https://api.devnet.solana.com
# Path to the oracle keypair JSON (the key set as `oracle` on each market).
ORACLE_KEYPAIR=./oracle.json
# Program id (must match Anchor.toml / declare_id! after `anchor keys sync`).
PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS

# --- TxODDS / TxLINE (https://txline.txodds.com/documentation/quickstart) ---
# Leave TXODDS_API_TOKEN empty to run in MOCK mode (deterministic scripted
# fixtures) so you can demo the full settlement flow with no external key.
#
# To go live (World Cup data is on FREE service levels 1 / 12):
#   1. POST https://txline.txodds.com/auth/guest/start  -> guest JWT (auto-fetched
#      by the relayer; or paste one into TXODDS_GUEST_JWT)
#   2. Activate a subscription for the free World Cup leagues (on-chain, via your
#      wallet) -> returns the long-lived API token below.
TXODDS_API_TOKEN=
TXODDS_GUEST_JWT=
TXODDS_BASE_URL=https://txline.txodds.com
# Filter the fixtures snapshot to the World Cup competition id (leave empty = all).
TXODDS_COMPETITION_ID=
# How often to poll for finished matches (ms).
POLL_INTERVAL_MS=15000

# --- Market admin (only needed by create-market.ts) ---
ADMIN_KEYPAIR=~/.config/solana/id.json
USDC_MINT=
TREASURY_TOKEN_ACCOUNT=
# Default protocol fee in basis points (200 = 2%).
DEFAULT_FEE_BPS=200
# Default dispute window in seconds (3600 = 1h).
DEFAULT_DISPUTE_WINDOW=3600
